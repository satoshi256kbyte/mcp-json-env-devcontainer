{
    "name": "mcp-json-env-devcontainer",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/aws-cli:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "GitHub.copilot",
                "GitHub.copilot-chat",
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "yzhang.markdown-all-in-one",
                "GitHub.vscode-pull-request-github",
                "eamodio.gitlens",
                "bierner.markdown-mermaid"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "[markdown]": {
                    "editor.defaultFormatter": "yzhang.markdown-all-in-one"
                }
            }
        }
    },
    "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && yes | bash -c \"$(curl -fsSL https://cli.kiro.dev/install)\" && curl -fsSL https://claude.ai/install.sh | bash && uv sync",
    "remoteEnv": {
        "AWS_REGION": "ap-northeast-1",
        "HOME": "/home/vscode",
        "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}",
        "GITHUB_TOKEN": "",
        "GIT_CONFIG_COUNT": "1",
        "GIT_CONFIG_KEY_0": "credential.helper",
        "GIT_CONFIG_VALUE_0": ""
    },
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.aws,target=/home/vscode/.aws,type=bind,consistency=cached",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json,target=/home/vscode/.claude.json,type=bind,consistency=cached",
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached"
    ],
    "initializeCommand": "touch ${localEnv:HOME}${localEnv:USERPROFILE}/.claude.json .devcontainer/.env.secrets",
    "runArgs": [
        "--env-file",
        ".devcontainer/.env.secrets"
    ]
}